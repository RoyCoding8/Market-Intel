LLM_MODEL=openai/mimo-v2.5-pro
OPENAI_API_KEY=
OPENAI_API_BASE=https://opengateway.gitlawb.com/v1
# NOTE: OPENAI_API_KEY is also used by any OpenAI-compatible provider
# (e.g. Opengateway, vLLM, LM Studio). Set OPENAI_API_BASE to point
# litellm at the alternative endpoint; the openai/ model prefix still applies.

# Providers: set LLM_MODEL + the matching key(s) below
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# DEEPSEEK_API_KEY=...
# MISTRAL_API_KEY=...
# COHERE_API_KEY=...
# GROQ_API_KEY=...
# TOGETHERAI_API_KEY=...
# FIREWORKS_API_KEY=...
# REPLICATE_API_TOKEN=...
# HUGGINGFACE_API_KEY=...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# XAI_API_KEY=...
# NVIDIA_NIM_API_KEY=...
# CEREBRAS_API_KEY=...
# SAMBANOVA_API_KEY=...
# DATABRICKS_API_KEY=...
# DATABRICKS_API_BASE=https://your-workspace.databricks.com/serving-endpoints
# XIAOMI_MIMO_API_KEY=...
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# OLLAMA_API_BASE=http://localhost:11434

BRIGHT_DATA_CUSTOMER_ID=
BRIGHT_DATA_ZONE=
BRIGHT_DATA_PASSWORD=

MAX_PAGES_PER_COMPETITOR=20
VERIFICATION_PASSES=2
REQUEST_DELAY_SECONDS=1.0
LLM_TIMEOUT_SECONDS=60
MAX_CONCURRENT_JOBS=5
LITELLM_DEBUG=0

# LLM rate limiting
LLM_RPM=10
MIN_PAGE_QUALITY=0.3
LLM_RATE_LIMIT_WINDOW=60
LLM_CHUNK_DELAY=2

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./data/market_intel.db
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
IGNORE_ROBOTS_TXT=1

# API_KEY=
# MAX_BODY_BYTES=1048576
PIPELINE_TIMEOUT_SECONDS=1800
NEXT_PUBLIC_API_URL=http://localhost:8000
