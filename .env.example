# ╔══════════════════════════════════════════════════════════════════════╗
# ║           Market Intelligence Agent — Environment Configuration     ║
# ╠══════════════════════════════════════════════════════════════════════╣
# ║  Copy to .env and fill in your API keys.                           ║
# ║  At least ONE LLM provider key is required.                        ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── LLM Provider ───────────────────────────────────────────────────────
# Set the model to use (litellm format: provider/model-name)
# The system supports ANY provider litellm supports (100+).
# See https://docs.litellm.ai/docs/providers for full list.
#
# Each provider has its own prefix and API key env var.
#
# Xiaomi MiMo (via Opengateway — free, unlimited):
#   LLM_MODEL=openai/mimo-v2.5-pro               + OPENAI_API_BASE=https://opengateway.gitlawb.com/v1
#                                                  + OPENAI_API_KEY=ogw_live_... (from gitlawb.com/opengateway)
#
# Xiaomi MiMo (direct — native litellm provider):
#   LLM_MODEL=xiaomi_mimo/mimo-v2.5-pro           + XIAOMI_MIMO_API_KEY=...
#
# OpenAI:
#   LLM_MODEL=openai/gpt-4o                       + OPENAI_API_KEY=sk-...
#
# Anthropic:
#   LLM_MODEL=anthropic/claude-sonnet-4-20250514   + ANTHROPIC_API_KEY=sk-ant-...
#
# Google Gemini (AI Studio):
#   LLM_MODEL=gemini/gemini-2.5-pro                + GEMINI_API_KEY=...
#
# Google Vertex AI:
#   LLM_MODEL=vertex_ai/gemini-2.0-flash           + GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
#
# Azure OpenAI:
#   LLM_MODEL=azure/gpt-4o                         + AZURE_API_KEY=... + AZURE_API_BASE=https://...
#
# DeepSeek:
#   LLM_MODEL=deepseek/deepseek-chat               + DEEPSEEK_API_KEY=...
#
# Mistral:
#   LLM_MODEL=mistral/mistral-large-latest          + MISTRAL_API_KEY=...
#
# Cohere:
#   LLM_MODEL=cohere/command-r-plus                + COHERE_API_KEY=...
#
# Groq:
#   LLM_MODEL=groq/llama-3.3-70b-versatile         + GROQ_API_KEY=...
#
# Together AI:
#   LLM_MODEL=together_ai/meta-llama/Llama-3-70b-chat-hf + TOGETHERAI_API_KEY=...
#
# Fireworks AI:
#   LLM_MODEL=fireworks_ai/accounts/fireworks/models/llama-v3-70b + FIREWORKS_API_KEY=...
#
# Replicate:
#   LLM_MODEL=replicate/meta/llama-2-70b-chat      + REPLICATE_API_TOKEN=...
#
# Hugging Face:
#   LLM_MODEL=huggingface/bigscience/bloom          + HUGGINGFACE_API_KEY=...
#
# AWS Bedrock:
#   LLM_MODEL=bedrock/anthropic.claude-3-sonnet    + AWS_ACCESS_KEY_ID=... + AWS_SECRET_ACCESS_KEY=...
#
# xAI (Grok):
#   LLM_MODEL=xai/grok-2                           + XAI_API_KEY=...
#
# Nvidia NIM:
#   LLM_MODEL=nvidia_nim/meta/llama-3.1-405b-instruct + NVIDIA_NIM_API_KEY=...
#
# Cerebras:
#   LLM_MODEL=cerebras/llama3.1-70b                + CEREBRAS_API_KEY=...
#
# SambaNova:
#   LLM_MODEL=sambanova/Meta-Llama-3.1-8B-Instruct + SAMBANOVA_API_KEY=...
#
# Databricks:
#   LLM_MODEL=databricks/databricks-meta-llama-3-1-70b-instruct + DATABRICKS_API_KEY=...
#
# Ollama (local):
#   LLM_MODEL=ollama/llama3.1                      + OLLAMA_API_BASE=http://localhost:11434
#
# Any OpenAI-compatible endpoint (self-hosted, vLLM, etc.):
#   LLM_MODEL=openai/your-model-name               + OPENAI_API_BASE=http://localhost:8080/v1
LLM_MODEL=openai/gpt-4o

# ─── Xiaomi MiMo (via Opengateway — free, unlimited) ───────────────────
# This is the default for this project. Sign up at https://gitlawb.com/opengateway
# to generate an API key (starts with ogw_live_...).
# OPENAI_API_KEY=ogw_live_...
# OPENAI_API_BASE=https://opengateway.gitlawb.com/v1

# ─── OpenAI ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1  # optional OpenAI-compatible base URL
# OPENAI_ORG_ID=org-...                               # optional org ID

# ─── Xiaomi MiMo (direct) ───────────────────────────────────────────────
# Alternative to Opengateway — uses Xiaomi's native API directly.
# Get key at https://platform.xiaomimimo.com
# XIAOMI_MIMO_API_KEY=

# ─── Bright Data Web Unlocker (hackathon requirement) ─────────────────────
# When all three credentials are present, scraper traffic is routed through
# Bright Data's Web Unlocker proxy. Leave blank for direct local development.
BRIGHT_DATA_CUSTOMER_ID=
BRIGHT_DATA_ZONE=
BRIGHT_DATA_PASSWORD=
# BRIGHT_DATA_COUNTRY=us
# BRIGHT_DATA_DEBUG=true
# BRIGHT_DATA_CA_CERT=/path/to/brightdata_proxy_ca.crt
# BRIGHT_DATA_VERIFY_SSL=false
# BRIGHT_DATA_HOST=brd.superproxy.io
# BRIGHT_DATA_PORT=33335

# ─── Anthropic (Claude) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Google (Gemini / Vertex AI) ────────────────────────────────────────
GEMINI_API_KEY=                          # Google AI Studio
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json  # Vertex AI
# VERTEX_PROJECT=your-gcp-project
# VERTEX_LOCATION=us-central1

# ─── Azure OpenAI ───────────────────────────────────────────────────────
# AZURE_API_KEY=
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2024-02-15-preview
# AZURE_DEPLOYMENT=gpt-4o-deployment

# ─── DeepSeek ───────────────────────────────────────────────────────────
# DEEPSEEK_API_KEY=

# ─── Mistral ────────────────────────────────────────────────────────────
# MISTRAL_API_KEY=

# ─── Cohere ─────────────────────────────────────────────────────────────
# COHERE_API_KEY=

# ─── Groq ───────────────────────────────────────────────────────────────
# GROQ_API_KEY=

# ─── Together AI ────────────────────────────────────────────────────────
# TOGETHERAI_API_KEY=

# ─── Fireworks AI ───────────────────────────────────────────────────────
# FIREWORKS_API_KEY=

# ─── Replicate ──────────────────────────────────────────────────────────
# REPLICATE_API_TOKEN=

# ─── Hugging Face ───────────────────────────────────────────────────────
# HUGGINGFACE_API_KEY=

# ─── AWS Bedrock ────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION_NAME=us-east-1

# ─── xAI (Grok) ────────────────────────────────────────────────────────
# XAI_API_KEY=

# ─── Ollama (local) ────────────────────────────────────────────────────
# OLLAMA_API_BASE=http://localhost:11434  # default Ollama endpoint

# ─── Nvidia NIM ─────────────────────────────────────────────────────────
# NVIDIA_NIM_API_KEY=

# ─── Cerebras ───────────────────────────────────────────────────────────
# CEREBRAS_API_KEY=

# ─── SambaNova ──────────────────────────────────────────────────────────
# SAMBANOVA_API_KEY=

# ─── Databricks ─────────────────────────────────────────────────────────
# DATABRICKS_API_KEY=
# DATABRICKS_API_BASE=https://your-workspace.databricks.com/serving-endpoints

# ─── vLLM / OpenAI-compatible (any self-hosted model) ───────────────────
# OPENAI_API_KEY=sk-no-key-needed
# OPENAI_API_BASE=http://localhost:8080/v1

# ─── Engine Configuration ──────────────────────────────────────────────
MAX_PAGES_PER_COMPETITOR=20             # max pages to scrape per competitor
VERIFICATION_PASSES=2                   # multi-pass verification count
REQUEST_DELAY_SECONDS=1.0              # delay between scrape requests (rate limiting)
LLM_TIMEOUT_SECONDS=60                 # per-LLM-call timeout
MAX_CONCURRENT_JOBS=5                  # max parallel analysis jobs
MAX_COMPETITORS_PER_JOB=10             # max competitors per job

# ─── Backend Configuration ─────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./data/market_intel.db  # SQLite for job persistence
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
LOG_LEVEL=INFO

# ─── Authentication (optional) ─────────────────────────────────────────
# AUTH_ENABLED=false
# AUTH_SECRET_KEY=change-me-to-a-random-secret
# AUTH_TOKEN_EXPIRY_HOURS=24

# ─── Frontend ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
